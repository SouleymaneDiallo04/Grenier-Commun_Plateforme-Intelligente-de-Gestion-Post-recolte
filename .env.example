# ─── DJANGO ───────────────────────────────────────────────────────────────────
SECRET_KEY=votre-secret-key-tres-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── BASE DE DONNÉES ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/grenier_commun

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ─── EMAIL ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app

# ─── SMS (TWILIO) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── TRADUCTION IA ────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_votre_cle_api
GOOGLE_TRANSLATE_API_KEY=votre-cle-google

# ─── CLOUDINARY (stockage fichiers) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret

# ─── CELERY ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
